    .music-sidebar {
      background: linear-gradient(to bottom, red, purple, blue);
      padding: 20px;
      border-radius: 15px;
      display: inline-block;
      margin-top: 50px;
    }

    .music-sidebar h3 {
      margin-bottom: 15px;
    }

    .music-sidebar iframe {
      display: block;
      margin: 10px auto;
      border-radius: 10px;
    }

    /* === Assembly Line (Left to Right) === */
    .gif-assembly-line {
      width: 100%;
      overflow: hidden;
      background: rgba(0, 0, 0, 0.8);
      padding: 10px 0;
      border-top: 3px solid #ff00ff;
      border-bottom: 3px solid #00ffff;
      margin-top: 50px;
      white-space: nowrap;
    }

    .gif-track {
      display: inline-flex;
      animation: scrollRight 80s linear infinite;
    }

    .gif-assembly-line:hover .gif-track {
      animation-play-state: paused;
    }

    .gif-track img {
      height: 80px;
      margin: 0 20px;
      border-radius: 10px;
    }

    @keyframes scrollRight {
      0% { transform: translateX(-50%); }
      100% { transform: translateX(0); }
    }

    /* === Stamp Line (Right to Left) === */
    .gif-stamps-line {
      width: 100%;
      overflow: hidden;
      background: rgba(20, 20, 20, 0.8);
      padding: 10px 0;
      border-top: 3px solid #00ffff;
      border-bottom: 3px solid #ff00ff;
      margin-top: 20px;
      white-space: nowrap;
    }

    .gif-stamps-track {
      display: inline-flex;
      animation: scrollLeft 90s linear infinite;
    }

    .gif-stamps-line:hover .gif-stamps-track {
      animation-play-state: paused;
    }

    .gif-stamps-track img {
      height: 60px;
      margin: 0 15px;
      border-radius: 8px;
    }

    @keyframes scrollLeft {
      0% { transform: translateX(0); }
      100% { transform: translateX(-50%); }
    }

    .footer {
      text-align: center;
      padding: 10px;
      background: rgba(34, 34, 34, 0.9);
      position: fixed;
      width: 100%;
      bottom: 0;
    }

    .footer p {
      font-family: 'Press Start 2P';
      font-size: 1rem;
      color: #00ff00;
      text-shadow: 0 0 10px #00ff00, 0 0 20px #ff00ff;
      animation: glow 1.5s infinite alternate;
    }

    @keyframes glow {
      0% { text-shadow: 0 0 5px #00ff00; }
      100% { text-shadow: 0 0 15px #ff00ff; }
    }
  </style>
